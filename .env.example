# .env.example

# Hugging Face API token (get one free at https://huggingface.co/settings/tokens)
HF_API_TOKEN="your_huggingface_api_token"

# Optional: override the default Llama 2 model endpoint
# HF_MODEL_URL="https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-chat-hf"

# Chunk Size (words per chunk when splitting documents)
CHUNK_SIZE=200

# Number of top chunks to retrieve per query
TOP_K=5

# Temperature for LLM generation
TEMPERATURE=0.7
